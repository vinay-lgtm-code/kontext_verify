{
  "name": "kontext-sdk",
  "version": "1.0.0",
  "description": "Payment control plane SDK for stablecoin payments across Base, Ethereum, and Solana.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kontext",
    "payment-lifecycle",
    "payment-control-plane",
    "usdc",
    "stablecoin",
    "policy-engine",
    "provider-adapter",
    "workspace-profile",
    "x402",
    "base",
    "circle",
    "bridge",
    "modern-treasury",
    "digest-chain"
  ],
  "author": "Legaci Labs Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://www.github.com/legaci-labs/kontext"
  },
  "homepage": "https://getkontext.com",
  "bugs": {
    "url": "https://www.github.com/legaci-labs/kontext/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "dependencies": {
    "@kontext/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "viem": "^2.46.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
