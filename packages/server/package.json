{
  "name": "@kontext/server",
  "version": "0.13.0",
  "private": true,
  "description": "Kontext backend API service (GCP Cloud Run ready)",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "build:vercel": "esbuild src/vercel-entry.ts --bundle --format=esm --platform=node --target=node18 --outfile=api/index.mjs --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.11.0",
    "@react-pdf/renderer": "^4.3.0",
    "hono": "^4.4.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "pg": "^8.13.0",
    "react": "^18.3.0",
    "resend": "^6.9.4",
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
